# Calendly URL is set in src/Consultation.jsx (CALENDLY_URL).

# Staff page (/admin.html): footer “—” link, or open /admin.html directly.
#
# Local dev (`npm run dev`): Vite reads this from .env (inlined in the bundle — light gate only).
VITE_ADMIN_PASSWORD=
#
# Production (Vercel): prefer **server** env (never shipped in static JS). On project **groundwork-hr**
# → Settings → Environment Variables → Production, add:
#   ADMIN_STAFF_PASSWORD=your-staff-password
# The /api/verify-admin-password route checks that at sign-in. VITE_ADMIN_PASSWORD is also accepted
# server-side if you already use that name. Link team shared vars to groundwork-hr.
# After adding this file’s api/ routes, deploy once; you can change ADMIN_STAFF_PASSWORD in the
# dashboard later without rebuilding the site.
ADMIN_STAFF_PASSWORD=

# --- Supabase (consultation form storage + admin list) ---
# Use a BRAND-NEW Supabase project created only for GroundWork HR.
# Do NOT reuse project URL, anon key, or service role from Route of Flight or any other app—
# keep databases and credentials completely separate.
# After creating the project, run consultation-setup.sql in the Supabase SQL editor, then paste:
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
