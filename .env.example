# Calendly URL is set in src/Consultation.jsx (CALENDLY_URL).

# Staff page (/admin.html): on the homepage footer, click the "—" between the company name
# and the tagline. Then set a password here:
# Note: Vite inlines this in the client bundle — fine for a light gate, not for high-security secrets.
# Production (Vercel): on project **groundwork-hr** → Settings → Environment Variables → Production, then redeploy.
# Team “shared” variables only apply after you link them to that project (Link to Projects).
VITE_ADMIN_PASSWORD=

# --- Supabase (consultation form storage + admin list) ---
# Use a BRAND-NEW Supabase project created only for GroundWork HR.
# Do NOT reuse project URL, anon key, or service role from Route of Flight or any other app—
# keep databases and credentials completely separate.
# After creating the project, run consultation-setup.sql in the Supabase SQL editor, then paste:
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
